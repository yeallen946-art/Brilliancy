# Copy to pipeline/.env (gitignored) and fill in. Never commit real keys.
# Used by 4_annotate.py. Set ANNOTATE_PROVIDER=openrouter to make OpenRouter the default
# (no need to pass --provider every run).
ANNOTATE_PROVIDER=openrouter

# Your OpenRouter key (https://openrouter.ai/keys). Rotate if it has ever been shared.
OPENROUTER_API_KEY=sk-or-...

# OpenRouter model slug. Defaults to anthropic/claude-opus-4-8 if unset.
# Must be a model that supports structured outputs (json_schema response_format).
OPENROUTER_MODEL=anthropic/claude-opus-4-8
