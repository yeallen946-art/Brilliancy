# Xcode project is generated from project.yml by XcodeGen — do not commit it.
*.xcodeproj/
.xcodegen/

# Xcode user/build artifacts
xcuserdata/
DerivedData/
build/
*.xcworkspace/xcuserdata/

# Swift Package Manager
.build/
.swiftpm/

# macOS
.DS_Store

# Python pipeline
pipeline/.venv/
__pycache__/
*.pyc
.pytest_cache/

# Built content artifacts (generated by pipeline 7_build.py)
content/content.sqlite
content/daily/*.json

# Secrets — never commit
.env
*.p8
*.mobileprovision
