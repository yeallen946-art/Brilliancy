/* 设计系统(UI_FLOW §4.1 的小程序映射):深色外壳 + 金色 CTA + 三档反馈色 */
page {
  background: #0f141a;
  color: #ecf0f4;
  font-size: 30rpx;
}

.screen {
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #1b222b;
  border: 1rpx solid #28313b;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.caption {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #94a1ae;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  margin: 16rpx 0;
}

.secondary {
  color: #94a1ae;
  font-size: 26rpx;
  line-height: 1.6;
}

.btn-gold {
  background: #e6b450;
  color: #2e2103;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 32rpx;
}

.btn-gold::after { border: none; }

.band-green  { color: #57b98a; }
.band-yellow { color: #e0b84a; }
.band-red    { color: #e07a6a; }
.gold        { color: #e6b450; }
